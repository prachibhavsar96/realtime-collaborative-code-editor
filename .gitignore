# Dependencies
# Ignore dependency installs anywhere in the monorepo.
node_modules/
**/node_modules/

# Build output
# React/Vite and Node/TypeScript production artifacts.
dist/
**/dist/
build/
**/build/

# Environment files
# Keep example templates tracked, but never commit real secrets.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Logs
# Runtime, dev-server, npm, and diagnostic logs.
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript cache
# Incremental build metadata generated by tsc.
*.tsbuildinfo
**/*.tsbuildinfo

# Runtime uploads and generated files
# Local/generated workspace content should not be committed.
uploads/
**/uploads/
tmp/
**/tmp/
temp/
**/temp/
cache/
**/cache/

# Coverage and test output
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/

# OS and editor files
.DS_Store
**/.DS_Store
Thumbs.db
**/Thumbs.db
.vscode/
**/.vscode/
.idea/
**/.idea/

# Package manager caches
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

